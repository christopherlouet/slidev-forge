{
  "name": "slidev-forge",
  "version": "2.0.0",
  "description": "Initialisateur de projets Slidev avec themes visuels et configuration YAML",
  "type": "module",
  "license": "GPL-3.0",
  "homepage": "https://christopherlouet.github.io/slidev-forge/",
  "repository": {
    "type": "git",
    "url": "https://github.com/christopherlouet/slidev-forge.git"
  },
  "keywords": [
    "slidev",
    "presentation",
    "scaffold",
    "cli",
    "slides",
    "generator"
  ],
  "bin": {
    "slidev-forge": "./bin/slidev-forge.js"
  },
  "files": [
    "bin/",
    "dist/"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build": "tsc && cp -r src/static/. dist/static/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@inquirer/prompts": "^7.10.1",
    "picocolors": "^1.1.1",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^3.0.5"
  },
  "engines": {
    "node": ">=20"
  }
}
